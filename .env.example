# Copy to .env and fill in. .env is gitignored.
#
# NOTE: No ANTHROPIC_API_KEY is needed for this project.
# Rule extraction, clause generation, SHACL/test-case generation, and Telugu
# translation are all done by Claude Code (you, in conversation) reading
# batch files from data/*_batches/ and writing results to data/*_results/.

# ── Postgres ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme
POSTGRES_URL=postgresql://apuser:changeme@localhost:5432/ap_knowledge

# ── Qdrant (vector store for P2 clause concepts) ────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=clause_concepts

# ── Apache Jena Fuseki (SHACL store for P1 rules) ───────────────────────────
FUSEKI_URL=http://localhost:3030
FUSEKI_PASSWORD=admin
FUSEKI_DATASET=ap_procurement

# ── BGE-M3 embedding model (HuggingFace identifier) ─────────────────────────
BGE_M3_MODEL=BAAI/bge-m3

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
