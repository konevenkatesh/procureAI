source_documents/e_procurement/**/*.jpg
source_documents/e_procurement/**/*.jpeg
source_documents/e_procurement/**/*.JPG
source_documents/e_procurement/**/*.tif
source_documents/e_procurement/**/*.doc
source_documents/e_procurement/**/*.DOC
