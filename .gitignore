# Source PDFs are large — track presence via .gitkeep, not the files themselves
source_documents/**/raw_pdf/*.pdf
source_documents/**/raw_pdf/*.PDF
source_documents/**/raw/*.pdf
source_documents/**/raw/*.PDF
source_documents/**/raw/*.docx
source_documents/**/raw/*.DOCX

# Processed Markdown CAN be committed (it's text, useful for reproducibility)
# Comment out the next two lines if you want to commit them:
source_documents/**/processed_md/*.md

# Docker volumes (if mounted locally)
postgres_data/
qdrant_data/
fuseki_data/

# Logs
*.log
logs/

# Failed-section retry files
data/failed_sections.json

# Generated batch files + manifest (regenerated by scripts/prepare_extraction_batches.py)
