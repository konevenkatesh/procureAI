.mypy_cache/

# IDE
.vscode/
.idea/
*.swp
.DS_Store
**/.DS_Store

# Claude Code working state
.claude/

# Source PDFs are large — track presence via .gitkeep, not the files themselves
source_documents/**/raw_pdf/*.pdf
source_documents/**/raw_pdf/*.PDF
source_documents/**/raw/*.pdf
source_documents/**/raw/*.PDF
source_documents/**/raw/*.docx
source_documents/**/raw/*.DOCX

# Processed Markdown CAN be committed (it's text, useful for reproducibility)
# Comment out the next two lines if you want to commit them:
source_documents/**/processed_md/*.md

# Docker volumes (if mounted locally)
postgres_data/
qdrant_data/
fuseki_data/

# Logs
*.log
logs/

# Failed-section retry files
data/failed_sections.json

# Generated batch files + manifest (regenerated by scripts/prepare_extraction_batches.py)
data/extraction_batches/rules/*.json
data/extraction_batches/clauses/*.json
data/extraction_batches/manifest.json
data/extraction_results/rules/*.json
data/extraction_results/clauses/*.json
data/clause_batches/*.json
data/clause_results/*.json
data/telugu_batches/*.json
data/telugu_results/*.json
data/shacl_batches/*.json
data/shacl_results/*.json
data/testcase_batches/*.json
data/testcase_results/*.json
data/concept_batches/*.json
data/concept_results/*.json

# Corpus-scoped batches (regenerable by scripts/prepare_*_batches.py — keep results, not batches)
data/extraction_batches/ap_state/
data/extraction_batches/e_procurement/

# E-procurement source documents — track presence via processed_md, not raw bulk files
source_documents/e_procurement/**/*.pdf
source_documents/e_procurement/**/*.PDF
source_documents/e_procurement/**/*.docx
source_documents/e_procurement/**/*.DOCX
